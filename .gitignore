# =============================================================================
# NexoraGrid .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
.turbo/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.production is intentionally committed (no secrets, only public URLs)

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output/

# Cache
.cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker
.docker/

# Prisma
backend/prisma/migrations/dev.db
backend/prisma/*.db

# Test artifacts
test-results/
playwright-report/
playwright/.cache/

# Uploads (local dev)
uploads/
public/uploads/

# Certificates
*.pem
*.key
*.crt
*.p12

# Misc
*.tgz
.yarn-integrity
